# --- Database ---
# Matches docker-compose.yml
DATABASE_URL="postgresql://dgdapp:dgdapp@localhost:5433/dgdapp?schema=public"

# --- Auth.js (NextAuth v5) ---
AUTH_SECRET="generate-with: npx auth secret"
AUTH_URL="http://localhost:3000"

# --- OAuth providers (RF-01) — leave empty to hide the button ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- File storage (dev: local disk) ---
UPLOAD_DIR="./public/uploads"
